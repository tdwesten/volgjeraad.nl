APP_NAME=Volgjeraad
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=volgjeraad
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Lokaal: Mailpit (smtp op 127.0.0.1:1025). Productie: zet MAIL_MAILER=lettermint + LETTERMINT_PROJECT_TOKEN.
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="nieuwsbrief@mail.volgjeraad.nl"
MAIL_FROM_NAME="Volgjeraad"

LETTERMINT_PROJECT_TOKEN=

OPENAI_API_KEY=
YOUTUBE_API_KEY=
SUPADATA_API_KEY=
AI_SUMMARY_MODEL=gpt-5.5-mini
AI_EVAL_MODEL=gpt-5.5-mini

ORI_BASE_URL=https://api.openraadsinformatie.nl/v1/elastic

VOLGJERAAD_LAUNCH_DATE=

ADMIN_EMAIL=
# ADMIN_PASSWORD is not stored here for security; set in local .env only

VITE_APP_NAME="${APP_NAME}"
